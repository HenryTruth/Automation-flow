# App
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/handover

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh

# NIN Encryption
NIN_ENCRYPTION_KEY=32-byte-hex-key-here

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Prembly (IdentityPass)
PREMBLY_API_KEY=
PREMBLY_APP_ID=
PREMBLY_BASE_URL=https://api.prembly.com

# Termii (SMS OTP)
TERMII_API_KEY=
TERMII_SENDER_ID=Handover
TERMII_BASE_URL=https://api.ng.termii.com

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Payment Provider (TBD)
PAYMENT_PROVIDER_API_KEY=
PAYMENT_WEBHOOK_SECRET=

# Resend (Email — optional)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@handover.ng
